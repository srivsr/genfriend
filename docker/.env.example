# Docker Compose Production Environment
# Copy to docker/.env and fill in real values
# Generate secrets: openssl rand -hex 32

# Database
DB_USER=genfriend
DB_PASSWORD=GENERATE_STRONG_PASSWORD_HERE
DB_NAME=genfriend

# Security
JWT_SECRET=GENERATE_WITH_openssl_rand_hex_32
ADMIN_SECRET_KEY=GENERATE_WITH_openssl_rand_hex_16

# Clerk Auth (required for production)
CLERK_SECRET_KEY=sk_live_xxx
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxx

# AI API Keys (at least one required)
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx
GROQ_API_KEY=gsk_xxx

# LLM Provider
LLM_PROVIDER=anthropic

# CORS
ALLOWED_ORIGINS=https://genfriend.app

# Frontend
NEXT_PUBLIC_API_URL=https://api.genfriend.app/api/v1

# Logging
LOG_LEVEL=WARNING
