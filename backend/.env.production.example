# Gen-Friend Production Configuration
# Copy this file to .env on your production server

# ===========================================
# APPLICATION SETTINGS
# ===========================================
APP_NAME=Gen-Friend
DEBUG=false
ENVIRONMENT=production
LOG_LEVEL=WARNING

# ===========================================
# DATABASE (PostgreSQL Required)
# ===========================================
DATABASE_URL=postgresql+asyncpg://user:STRONG_PASSWORD@db-host:5432/genfriend

# CRITICAL: Must be false in production!
AUTO_CREATE_TABLES=false

# ===========================================
# REDIS (Recommended for production)
# ===========================================
REDIS_URL=redis://redis-host:6379
REDIS_ENABLED=true

# ===========================================
# SECURITY (CHANGE THESE!)
# ===========================================
# Generate with: openssl rand -hex 32
JWT_SECRET=GENERATE_A_STRONG_64_CHAR_SECRET_KEY_HERE
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Generate with: openssl rand -hex 16
ADMIN_SECRET_KEY=GENERATE_ANOTHER_STRONG_KEY_HERE

# ===========================================
# CORS (Your production domains)
# ===========================================
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ===========================================
# AI SERVICES
# ===========================================
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx
GROQ_API_KEY=gsk_xxx

# Provider selection
STT_PROVIDER=groq
LLM_PROVIDER=anthropic
TTS_PROVIDER=openai

# ===========================================
# CLERK AUTHENTICATION
# ===========================================
CLERK_SECRET_KEY=sk_live_xxx
CLERK_PUBLISHABLE_KEY=pk_live_xxx

# ===========================================
# EMBEDDINGS
# ===========================================
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
ENABLE_ADVANCED_RAG=false

# ===========================================
# BACKUP SETTINGS
# ===========================================
BACKUP_ENABLED=true
BACKUP_PATH=/var/backups/genfriend
BACKUP_RETENTION_DAYS=30

# ===========================================
# COST TRACKING
# ===========================================
ENABLE_COST_TRACKING=true
