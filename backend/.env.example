# Gen-Friend Backend Configuration
# Copy this file to .env and fill in your values

# ===========================================
# APPLICATION SETTINGS
# ===========================================
APP_NAME=Gen-Friend
DEBUG=true
ENVIRONMENT=development  # development | staging | production
LOG_LEVEL=INFO

# ===========================================
# DATABASE
# ===========================================
# Development (SQLite)
# DATABASE_URL=sqlite+aiosqlite:///./genfriend.db

# Production (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/genfriend

# IMPORTANT: Set to false in production! Use Alembic migrations instead.
AUTO_CREATE_TABLES=true

# ===========================================
# REDIS (Optional - improves performance)
# ===========================================
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false

# ===========================================
# SECURITY
# ===========================================
# IMPORTANT: Change these in production!
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Admin panel access key
ADMIN_SECRET_KEY=dev-admin-secret

# ===========================================
# CORS (Allowed Frontend Origins)
# ===========================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3002,http://127.0.0.1:3002

# ===========================================
# AI SERVICES
# ===========================================
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx
GROQ_API_KEY=gsk_xxx

# Provider selection (groq is cheapest)
STT_PROVIDER=groq
LLM_PROVIDER=groq
TTS_PROVIDER=openai

# ===========================================
# CLERK AUTHENTICATION (Optional)
# ===========================================
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# ===========================================
# EMBEDDINGS (For RAG features)
# ===========================================
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
ENABLE_ADVANCED_RAG=false

# ===========================================
# BACKUP SETTINGS
# ===========================================
BACKUP_ENABLED=false
BACKUP_PATH=./backups
BACKUP_RETENTION_DAYS=30

# ===========================================
# COST TRACKING
# ===========================================
ENABLE_COST_TRACKING=true

# ===========================================
# PAYMENT PROCESSING
# ===========================================
# PayPal
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox  # sandbox | live

# Payoneer
PAYONEER_EMAIL=payments@yourdomain.com
PAYONEER_PARTNER_ID=your-partner-id

# Base URL for callbacks
BASE_URL=https://genfriend.srivsr.com
